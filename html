<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>100 نقطة مجانية</title>
<style>
body{font-family:system-ui;background:#0f172a;color:#fff;display:flex;align-items:center;justify-content:center;height:100vh;margin:0}
.card{background:#1e293b;padding:30px;border-radius:20px;text-align:center;max-width:320px;box-shadow:0 10px 30px rgba(0,0,0,.3)}
button{background:#22c55e;border:0;padding:15px 25px;border-radius:12px;color:#fff;font-size:18px;font-weight:bold;cursor:pointer;width:100%}
button:disabled{background:#475569;cursor:not-allowed}
#msg{margin-top:15px;font-size:14px}
</style>
</head>
<body>
<div class="card">
  <h2>🎁 100 نقطة مجانية</h2>
  <p>اضغط الزر مرة وحدة بس</p>
  <button id="btn">استلام النقاط</button>
  <div id="msg"></div>
</div>
<script>
const btn=document.getElementById('btn');const msg=document.getElementById('msg');
let deviceId=localStorage.getItem('device_id');if(!deviceId){deviceId=crypto.randomUUID();localStorage.setItem('device_id',deviceId);}
btn.onclick=async()=>{btn.disabled=true;msg.textContent='جاري التحقق...';try{const r=await fetch('/claim_points',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({device_id:deviceId})});const d=await r.json();msg.textContent=d.status==='ok'?`✅ تم اضافة ${d.points} نقطة`:d.msg;}catch(e){msg.textContent='صار خطأ حاول مرة ثانية';btn.disabled=false;}};
</script>
</body>
</html>